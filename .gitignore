# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Override files (often used for secrets or local configs)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Terraform plan files
*.tfplan
*.tfplan.json

# Lock file (optional: usually committed, but some teams ignore it)
# .terraform.lock.hcl

# Sensitive variable files
*.tfvars
*.tfvars.json

# Exclude local environment files
.env
.env.*

# Editor directories and files
.idea/
.vscode/
*.swp
*.swo
*~
*.dot

# OS generated files
.DS_Store
Thumbs.db

# Log files
*.log